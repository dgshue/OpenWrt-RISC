# OpenWrt "full router" package profile for the Orange Pi RV2 (spacemit/generic)
#
# Append this to an OpenWrt .config and run `make defconfig` to add a complete
# router/firewall/VPN feature set on top of the base spacemit image. See
# docs/router-build.md for details and the VPN/DNS notes.
#
#   cat /path/to/OpenWrt-RISC/config/rv2-router.config >> .config
#   ./scripts/feeds install -a
#   make defconfig && make -j"$(nproc)"

# --- VPN -----------------------------------------------------------------
# NOTE: modern LuCI has NO standalone OpenVPN/WireGuard app pages; both are
# configured as INTERFACE PROTOCOLS (Network > Interfaces > Protocol).
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_openvpn-openssl=y
CONFIG_PACKAGE_openvpn-easy-rsa=y
CONFIG_PACKAGE_luci-proto-openvpn=y

# --- Firewall / NAT extras (firewall4/nftables is in the base image) -----
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y

# --- DNS sink / adblock --------------------------------------------------
# dnsmasq is swapped for dnsmasq-full (nftset/DNSSEC/adblock reporting).
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_adblock=y
CONFIG_PACKAGE_luci-app-adblock=y
CONFIG_PACKAGE_https-dns-proxy=y
CONFIG_PACKAGE_luci-app-https-dns-proxy=y
CONFIG_PACKAGE_bind-dig=y

# --- IPv6 ----------------------------------------------------------------
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_odhcpd=y
CONFIG_PACKAGE_6in4=y
CONFIG_PACKAGE_6rd=y
CONFIG_PACKAGE_ds-lite=y

# --- QoS / DDNS / TLS ----------------------------------------------------
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-acme=y

# --- Monitoring ----------------------------------------------------------
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-network=y
CONFIG_PACKAGE_nlbwmon=y
CONFIG_PACKAGE_luci-app-nlbwmon=y

# --- System / misc -------------------------------------------------------
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ip-full=y

# --- Storage / SMB -------------------------------------------------------
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_ksmbd-server=y
CONFIG_PACKAGE_luci-app-ksmbd=y

# --- LuCI themes ---------------------------------------------------------
CONFIG_PACKAGE_luci-theme-material=y
CONFIG_PACKAGE_luci-theme-openwrt-2020=y
